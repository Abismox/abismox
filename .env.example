# ============================================
# ABISMOX // .env.example
# Copia este archivo a .env y rellena los valores
# chmod 600 .env
# ============================================

# ----- minimax (usado por build.py) -----
MINIMAX_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxx
MINIMAX_BASE_URL=https://api.minimax.chat/v1

# ----- GitHub deploy (usado por deploy.sh) -----
# PAT clásico con scope: repo
# Generar en: https://github.com/settings/tokens
GH_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Formato: usuario/repo (sin https://)
GITHUB_REPO=Abismox/abismox

# ----- Opcional: override de SITE_BASE_URL -----
# Por defecto: https://Abismox.github.io/abismox/
# Si usas custom domain: https://abismox.com/
SITE_BASE_URL=https://Abismox.github.io/abismox/